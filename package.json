{
  "name": "mantlesignal",
  "version": "1.0.0",
  "description": "AI-powered smart money intelligence and autonomous trading agent on Mantle Network",
  "private": true,
  "scripts": {
    "dev":            "next dev",
    "build":          "next build",
    "start":          "next start",
    "agent":          "ts-node -r tsconfig-paths/register agent/index.ts",
    "agent:dry":      "DRY_RUN=true ts-node -r tsconfig-paths/register agent/index.ts",
    "compile":        "cd contracts && npx hardhat compile",
    "deploy:testnet": "cd contracts && npx hardhat run ../scripts/deploy.ts --network mantleTestnet",
    "deploy:mainnet": "cd contracts && npx hardhat run ../scripts/deploy.ts --network mantle",
    "verify":         "cd contracts && npx hardhat verify --network mantleTestnet",
    "test":           "cd contracts && npx hardhat test",
    "typecheck":      "tsc --noEmit"
  },
  "dependencies": {
    "next":             "15.0.0",
    "react":            "19.0.0",
    "react-dom":        "19.0.0",
    "@anthropic-ai/sdk": "^0.36.0",
    "ethers":           "^6.13.0"
  },
  "devDependencies": {
    "typescript":                        "^5.5.0",
    "@types/node":                       "^22.0.0",
    "@types/react":                      "^19.0.0",
    "@types/react-dom":                  "^19.0.0",
    "tailwindcss":                       "^3.4.0",
    "autoprefixer":                      "^10.4.0",
    "postcss":                           "^8.4.0",
    "ts-node":                           "^10.9.0",
    "tsconfig-paths":                    "^4.2.0",
    "@nomicfoundation/hardhat-toolbox":  "^5.0.0",
    "hardhat":                           "^2.22.0",
    "dotenv":                            "^16.4.0"
  }
}
